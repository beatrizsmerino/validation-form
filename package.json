{
	"version": "2.6.0",
	"name": "validation-form",
	"private": true,
	"description": "Customized form with validation for different types of fields.",
	"author": {
		"name": "Beatriz Sopeña Merino",
		"email": "beatrizsmerino@gmail.com",
		"url": "https://github.com/beatrizsmerino"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/beatrizsmerino/validation-form.git"
	},
	"homepage": "https://beatrizsmerino.github.io/validation-form",
	"bugs": {
		"url": "https://github.com/beatrizsmerino/validation-form/issues"
	},
	"keywords": [
		"javascript",
		"form",
		"validation",
		"gulp",
		"sass"
	],
	"type": "module",
	"main": "index.js",
	"scripts": {
		"install:clean": "rm -rf node_modules package-lock.json",
		"prepare": "husky",
		"prettier:fix": "prettier --write './**/*.{css,scss,json,yml,yaml,js,cjs,mjs,html}'",
		"eslint:fix": "eslint './**/*.{json,js,cjs,mjs}' --fix --ignore-path .eslintignore",
		"stylelint:fix": "stylelint '**/*.{css,scss}' --fix --ignore-path .stylelintignore",
		"lint": "npm run prettier:fix && npm run eslint:fix && npm run stylelint:fix",
		"deploy": "chmod +x ./deploy.sh && ./deploy.sh"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"babel-core": "^6.26.3",
		"babel-polyfill": "^6.26.0",
		"babel-preset-env": "^1.7.0",
		"browser-sync": "^3.0.4",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-json": "^3.1.0",
		"eslint-plugin-prettier": "^5.5.5",
		"gulp": "^5.0.1",
		"gulp-autoprefixer": "^10.0.0",
		"gulp-babel": "^8.0.0",
		"gulp-clean-css": "^4.3.0",
		"gulp-concat": "^2.6.1",
		"gulp-line-ending-corrector": "^1.0.3",
		"gulp-rename": "^2.1.0",
		"gulp-sass": "^6.0.1",
		"gulp-sourcemaps": "^3.0.0",
		"gulp-uglify": "^3.0.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"sass": "^1.98.0",
		"stylelint": "^16.26.1",
		"stylelint-config-property-sort-order-smacss": "^11.2.0",
		"stylelint-config-sass-guidelines": "^12.1.0",
		"stylelint-config-standard": "^39.0.1",
		"stylelint-scss": "^7.0.0"
	},
	"engines": {
		"node": "24.14.1",
		"npm": "11.11.0",
		"gulp-cli": "3.0.0"
	},
	"overrides": {
		"@gulp-sourcemaps/identity-map": {
			"postcss": "^8.4.31"
		},
		"babel-core": {
			"json5": "^2.2.3",
			"babel-traverse": "npm:@babel/traverse@^7.28.5",
			"babel-types": "npm:@babel/types@^7.28.5"
		},
		"babel-preset-env": {
			"babel-traverse": "npm:@babel/traverse@^7.28.5"
		}
	}
}
